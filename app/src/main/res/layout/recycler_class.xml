<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:id="@+id/recycler_class_card"
        android:layout_width="wrap_content"
        android:layout_height="298dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:weightSum="5.5">

            <ImageView
                android:id="@+id/recycler_class_iv_class"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="4"
                android:scaleType="centerCrop"
                android:src="@drawable/boxfit" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="5dp"
                android:layout_weight="1.5"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.9"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/recycler_class_tv_title"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/jura_bold"
                        android:maxLines="1"
                        android:paddingLeft="10dp"
                        android:text="Title"
                        android:textColor="@color/black"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/recycler_class_tv_instructor"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:maxLines="1"
                        android:paddingLeft="10dp"
                        android:text="Instructor"
                        android:textColor="@color/umGrey"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/recycler_class_tv_intensity"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:maxLines="1"
                        android:paddingLeft="10dp"
                        android:text="Heavy"
                        android:textColor="@color/umGrey"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/classDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxLines="0"
                        android:text="Lorem"
                        android:textSize="18sp"
                        android:visibility="invisible" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_weight="0.1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/recycler_class_iv_calendar"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            android:paddingTop="5dp"
                            app:srcCompat="@drawable/calendar_black" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/recycler_class_tv_date"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/jura_bold"
                                android:paddingLeft="5dp"
                                android:text="26/05/2026"
                                android:textAlignment="textStart"
                                android:textColor="@color/black"
                                android:textSize="16sp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/recycler_class_tv_startTime"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/jura_bold"
                                    android:paddingLeft="5dp"
                                    android:text="11:30"
                                    android:textColor="@color/umGrey"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/recycler_class_tv_between"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/jura_bold"
                                    android:text="-"
                                    android:textAlignment="center"
                                    android:textColor="@color/umGrey"
                                    android:textSize="16sp" />

                                <TextView
                                    android:id="@+id/recycler_class_tv_endTime"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/jura_bold"
                                    android:text="13:00"
                                    android:textColor="@color/umGrey"
                                    android:textSize="14sp" />
                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/recycler_class_iv_capacity"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            app:srcCompat="@drawable/capacity_black" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/recycler_class_tv_currentCapacity"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/jura_bold"
                                android:paddingLeft="5dp"
                                android:text="5"
                                android:textColor="@color/umGrey"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/recycler_class_tv_separator"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/jura_bold"
                                android:text="/"
                                android:textColor="@color/umGrey"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/recycler_class_tv_maxCapacity"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/jura_bold"
                                android:text="20"
                                android:textColor="@color/umGrey"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </androidx.cardview.widget.CardView>
</LinearLayout>